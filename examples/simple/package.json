{
  "name": "simple",
  "version": "0.0.1",
  "description": "simple ts app",
  "main": ".",
  "directories": {
    "test": "tests"
  },
  "scripts": {
    "test": "bun test --preload ./src/testsetup/bun.ts --max-concurrency=1 --timeout 20000",
    "compile": "rm -rf dist && bunx ent-custom-compiler",
    "start": "docker compose -f docker-compose.dev.yml up --build",
    "codegen": "npm run codegen:bun",
    "codegen:docker": "docker compose -f docker-compose.dev.yml run --rm app tsent codegen",
    "codegen:node": "ENT_RUNTIME=node ENT_POSTGRES_DRIVER=pg go run ../../tsent/main.go codegen --disable_upgrade",
    "codegen:bun": "ENT_RUNTIME=bun ENT_POSTGRES_DRIVER=bun go run ../../tsent/main.go codegen --disable_upgrade",
    "upgrade": "docker compose -f docker-compose.dev.yml run --rm app tsent upgrade",
    "rebuild-image": "docker compose -f docker-compose.dev.yml build",
    "start-fast": "bun src/graphql/index.bun.ts",
    "start-fast:node": "npm run compile && node dist/graphql/index.js",
    "start-fast:bun": "bun src/graphql/index.bun.ts",
    "runtime:node": "ENT_RUNTIME=node ENT_POSTGRES_DRIVER=pg node -r ts-node/register/transpile-only -r tsconfig-paths/register src/scripts/node_runtime_smoke.ts",
    "runtime:bun": "ENT_RUNTIME=bun ENT_POSTGRES_DRIVER=bun bun src/scripts/bun_runtime_smoke.ts"
  },
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@snowtop/ent-graphql-tests": "^0.1.0-rc1",
    "@types/bcryptjs": "^2.4.2",
    "@types/express": "^4.17.11",
    "@types/jest": "^29.2.3",
    "@types/jsonwebtoken": "^8.5.1",
    "@types/passport": "^1.0.7",
    "@types/supertest": "^2.0.11",
    "cookie-parser": "^1.4.5",
    "jest": "^29.3.1",
    "jest-date-mock": "^1.0.8",
    "jest-expect-message": "^1.1.3",
    "supertest": "^6.1.3",
    "ts-jest": "^29.1.0",
    "ts-node": "^11.0.0-beta.1",
    "tsconfig-paths": "^3.11.0"
  },
  "dependencies": {
    "@snowtop/ent": "^0.2.7",
    "@snowtop/ent-email": "^0.1.0",
    "@snowtop/ent-passport": "^0.1.0",
    "@snowtop/ent-password": "^0.1.0",
    "@snowtop/ent-phonenumber": "^0.1.0",
    "@swc-node/core": "^1.10.6",
    "@swc-node/register": "^1.6.8",
    "@swc/core": "^1.3.100",
    "@types/express-session": "^1.17.3",
    "@types/graphql-upload": "^8.0.11",
    "@types/luxon": "^3.2.0",
    "@types/node": "^15.0.3",
    "@types/passport-jwt": "^3.0.5",
    "@types/passport-local": "^1.0.33",
    "@types/passport-strategy": "^0.2.35",
    "@types/pg": "^8.6.1",
    "@types/uuid": "^8.3.1",
    "bcryptjs": "^2.4.3",
    "camel-case": "^4.1.2",
    "csv-parse": "^4.15.4",
    "dataloader": "^2.0.0",
    "express": "^4.18.2",
    "express-session": "^1.17.1",
    "glob": "^8.0.3",
    "graphql": "16.8",
    "graphql-helix": "^1.13.0",
    "graphql-scalars": "^1.22.2",
    "graphql-type-json": "^0.3.2",
    "graphql-upload": "^13.0.0",
    "jsonwebtoken": "^9.0.0",
    "libphonenumber-js": "^1.7.56",
    "luxon": "^3.2.1",
    "passport": "^0.6.0",
    "passport-jwt": "^4.0.0",
    "passport-local": "^1.0.0",
    "passport-strategy": "^1.0.0",
    "pg": "^8.11.0",
    "snake-case": "^3.0.4",
    "uuid": "^8.3.2"
  }
}
