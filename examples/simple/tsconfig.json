{
  // TODO eventually generate this from an init step
  "compilerOptions": {
    "lib": ["es2018", "esnext.asynciterable"],
    "outDir": "./dist",
    "target": "es2020",
    "strictNullChecks": true,
    "module": "commonjs",
    "downlevelIteration": true,
    "baseUrl": ".",
    "paths": {
      "src/*": ["src/*"],
      "@snowtop/ent": ["../../ts/src/index.ts"],
      "@snowtop/ent/*": ["../../ts/src/*"],
      "@snowtop/ent-graphql-tests": ["../../ts/src/testutils/ent-graphql-tests/index.ts"],
      "@snowtop/ent-graphql-tests/*": ["../../ts/src/testutils/ent-graphql-tests/*"],
      "graphql": ["../../ts/node_modules/graphql/index.js"],
      "graphql/*": ["../../ts/node_modules/graphql/*"]
    },
    "moduleResolution": "node",
    "esModuleInterop": true,
    "strict": true,
    "noUnusedLocals": true,
    "skipLibCheck": true
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "tests/**/*"],
  "files": ["node_modules/jest-expect-message/types/index.d.ts"]
}
