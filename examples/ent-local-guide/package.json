{
  "name": "ent-local-guide",
  "version": "0.0.1",
  "description": "local guide postgis example",
  "private": true,
  "main": ".",
  "directories": {
    "test": "tests"
  },
  "scripts": {
    "test": "jest",
    "db:up": "docker compose -f docker-compose.dev.yml up -d db",
    "db:down": "docker compose -f docker-compose.dev.yml down",
    "codegen": "npm run db:up && LOCAL_SCRIPT_PATH=true LOCAL_AUTO_SCHEMA=true go run ../../tsent/main.go codegen",
    "upgrade": "npm run db:up && LOCAL_SCRIPT_PATH=true LOCAL_AUTO_SCHEMA=true go run ../../tsent/main.go upgrade"
  },
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/node": "^25.0.3",
    "@types/pg": "^8.16.0",
    "jest": "^30.2.0",
    "jest-expect-message": "^1.1.3",
    "ts-jest": "^29.4.6",
    "tsconfig-paths": "^4.2.0"
  },
  "dependencies": {
    "@snowtop/ent": "0.2.8",
    "@snowtop/ent-postgis": "file:../../ts/packages/ent-postgis",
    "pg": "^8.16.3"
  }
}
