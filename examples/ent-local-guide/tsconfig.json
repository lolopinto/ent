{
  "compilerOptions": {
    "lib": [
      "es2018",
      "esnext.asynciterable"
    ],
    "outDir": "dist",
    "target": "es2020",
    "strictNullChecks": true,
    "module": "commonjs",
    "downlevelIteration": true,
    "baseUrl": ".",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "paths": {
      "@snowtop/ent": [
        "../../ts/src/index.ts"
      ],
      "@snowtop/ent/*": [
        "../../ts/src/*"
      ],
      "@snowtop/ent-postgis": [
        "../../ts/packages/ent-postgis/src/postgis.ts"
      ],
      "src/*": [
        "./src/*"
      ]
    }
  },
  "include": [
    "src/**/*"
  ],
  "exclude": [
    "node_modules",
    "tests/**/*"
  ],
  "files": ["node_modules/jest-expect-message/types/index.d.ts"]
}
